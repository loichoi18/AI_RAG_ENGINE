# ---------------------------------------------------------------------------
# RAG Engine environment configuration.
# Copy to `.env` and adjust. All values have sane defaults in configs/settings.py,
# so the system runs with NO .env file and NO API keys (local Ollama).
# Nested settings use a double-underscore delimiter, e.g. RAG_QDRANT__HOST.
# ---------------------------------------------------------------------------

# --- Application -----------------------------------------------------------
RAG_APP_NAME=rag-engine
RAG_ENVIRONMENT=local
RAG_DEBUG=false

# --- API -------------------------------------------------------------------
RAG_API__HOST=0.0.0.0
RAG_API__PORT=8000

# --- Qdrant (vector store) -------------------------------------------------
RAG_QDRANT__HOST=localhost
RAG_QDRANT__PORT=6333
RAG_QDRANT__COLLECTION_NAME=documents
# Qdrant Cloud (managed): set the cluster host, enable TLS, and provide the key.
# RAG_QDRANT__HOST=xxxxxxxx-xxxx.aws.cloud.qdrant.io
# RAG_QDRANT__HTTPS=true
# RAG_QDRANT__API_KEY=your-qdrant-cloud-api-key

# --- CORS (allow the browser frontend to call this API) --------------------
# Comma-separated origins. Default "*" allows any (fine for demos).
# For production set to your deployed frontend, e.g.:
# RAG_CORS_ORIGINS=https://your-app.vercel.app
RAG_CORS_ORIGINS=*

# --- Embeddings (local, sentence-transformers) -----------------------------
RAG_EMBEDDINGS__EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RAG_EMBEDDINGS__DEVICE=cpu
RAG_EMBEDDINGS__BATCH_SIZE=32

# --- LLM (default provider: ollama, fully local) ---------------------------
RAG_LLM__PROVIDER=ollama
RAG_LLM__OLLAMA_BASE_URL=http://localhost:11434
RAG_LLM__OLLAMA_MODEL=llama3.1:8b
RAG_LLM__TEMPERATURE=0.0
RAG_LLM__MAX_TOKENS=1024
# For ONLINE deploy, switch to a hosted provider (no local model needed):
# RAG_LLM__PROVIDER=openai
# RAG_LLM__API_KEY=sk-...
#   (PROVIDER=anthropic also supported with the same RAG_LLM__API_KEY)

# --- Retrieval -------------------------------------------------------------
RAG_RETRIEVAL__TOP_K=5

# --- Logging ---------------------------------------------------------------
RAG_LOGGING__LOG_LEVEL=INFO
RAG_LOGGING__JSON_LOGS=true
